# ==============================================================================
# Muliao 环境变量模板
# ==============================================================================
#
# 每个团队一份完整 .env，所有配置都在同一个文件里：
#   cp .env.example teams/<name>/.env
#   vim teams/<name>/.env              # 填入 API keys 等
#
# run.sh --team <name> 首次运行时会自动复制。
# teams/*/.env 已被 .gitignore 排除（含敏感 key，不应入库）。
# ==============================================================================

# --------------------------------------------------------------------------- #
# 镜像 / 容器（仅开发机 Docker 工作流，RPi 裸机部署不使用）
# --------------------------------------------------------------------------- #

# Docker 镜像（run.sh / docker-compose.yml 使用）
# 容器名由 run.sh 根据 --team 动态设为 muliao-<team>，无需在此处设置
MULIAO_IMAGE=ghcr.io/muliaoio/muliao:latest

# --------------------------------------------------------------------------- #
# 数据目录（仅开发机 Docker 工作流）
# --------------------------------------------------------------------------- #
# 开发机：run.sh 自动根据 --team 设为 teams/<name>/
# RPi：OpenClaw 默认使用 ~/.openclaw/，无需显式设置

#MULIAO_DATA_DIR=/home/muliao/.openclaw

# --------------------------------------------------------------------------- #
# 系统
# --------------------------------------------------------------------------- #

# 时区（留空则自动从宿主机读取）
#TZ=Asia/Shanghai

# --------------------------------------------------------------------------- #
# AI API Keys
# --------------------------------------------------------------------------- #
# 至少配置一个 LLM provider

#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#DEEPSEEK_API_KEY=

# --------------------------------------------------------------------------- #
# IM Bot Tokens
# --------------------------------------------------------------------------- #

#TELEGRAM_BOT_TOKEN=
#DISCORD_BOT_TOKEN=
#SLACK_BOT_TOKEN=
#SLACK_APP_TOKEN=

# --------------------------------------------------------------------------- #
# OpenClaw Gateway
# --------------------------------------------------------------------------- #

# Gateway 认证 Token（可选，保护远程访问）
#OPENCLAW_GATEWAY_TOKEN=

# --------------------------------------------------------------------------- #
# RPi 部署（flash-ssd.sh 使用）
# --------------------------------------------------------------------------- #
# 以下配置仅在烧录时由 deploy/rpi/flash-ssd.sh 需要，不影响运行时。
# RPi 架构：裸机 Node.js + OpenClaw，Docker 仅用于 Agent Sandbox。
# 填好后无需每次通过命令行传参，直接 flash-ssd.sh /dev/sda --team <name> 即可。

# Tailscale pre-auth key
# 从 https://login.tailscale.com/admin/settings/keys 生成（建议勾选 Reusable）
#TAILSCALE_AUTHKEY=tskey-auth-xxx

# 主机名前缀（留空则与团队名相同；启动后自动追加序列号后 4 位，如 hermes-a1b2）
#HOSTNAME_PREFIX=hermes

# RPi 系统时区（仅影响 cloud-init 写入 RPi 的时区，不影响 Docker 容器）
# 留空则自动回退读取上方的 TZ 值；两者都不填则从开发机 /etc/timezone 读取
#TIMEZONE=Asia/Shanghai

# HDMI 输出分辨率（预设: 720p / 1080p / 2k / 4k，或自定义 WxH，如 1024x600）
# 默认 800x480 适配小触摸屏；终端字体模糊时换成与屏幕匹配的分辨率
#HDMI_RESOLUTION=1080p
