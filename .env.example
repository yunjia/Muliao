# ==============================================================================
# Muliao Docker Compose 环境变量
# ==============================================================================
#
# 复制为 .env 并填入实际值（项目根目录）：
#   cp .env.example .env
#
# run.sh 首次运行时也会自动复制。
# .env 已被 .gitignore 排除（含 API keys，不应入库）。
# ==============================================================================

# --------------------------------------------------------------------------- #
# 镜像 / 容器
# --------------------------------------------------------------------------- #

# Docker 镜像
MULIAO_IMAGE=ghcr.io/muliaoio/muliao:latest

# 容器名称
MULIAO_CONTAINER_NAME=muliao

# --------------------------------------------------------------------------- #
# 数据目录
# --------------------------------------------------------------------------- #
# 开发机：run.sh 自动根据 --team 设为 teams/<name>/
# RPi / 生产：在此处设为绝对路径

#MULIAO_DATA_DIR=/opt/muliao/data

# --------------------------------------------------------------------------- #
# 系统
# --------------------------------------------------------------------------- #

# 时区（留空则自动从宿主机读取）
#TZ=Asia/Shanghai

# --------------------------------------------------------------------------- #
# AI API Keys
# --------------------------------------------------------------------------- #
# 至少配置一个 LLM provider

#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#DEEPSEEK_API_KEY=

# --------------------------------------------------------------------------- #
# IM Bot Tokens
# --------------------------------------------------------------------------- #

#TELEGRAM_BOT_TOKEN=
#DISCORD_BOT_TOKEN=
#SLACK_BOT_TOKEN=
#SLACK_APP_TOKEN=

# --------------------------------------------------------------------------- #
# OpenClaw Gateway
# --------------------------------------------------------------------------- #

# Gateway 认证 Token（可选，保护远程访问）
#OPENCLAW_GATEWAY_TOKEN=
